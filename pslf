<script>
  // ====== STATE & PERSISTENCE ======
  const STORAGE_KEY = 'pslf_playbook_state_v1';

  function loadState() {
    try {
      const raw = localStorage.getItem(STORAGE_KEY);
      if (!raw) return null;
      return JSON.parse(raw);
    } catch (e) {
      return null;
    }
  }

  function saveState(state) {
    try {
      localStorage.setItem(STORAGE_KEY, JSON.stringify(state));
    } catch (e) {
      console.warn('Could not save state:', e);
    }
  }

  let state = loadState() || {
    count: 37,
    phasesComplete: {},
    stepsChecked: {},
    checklistItems: {},
    notes: ''
  };

  // ====== PROGRESS RING ======
  const RING_CIRCUMFERENCE = 2 * Math.PI * 84; // r=84

  function updateProgress() {
    const count = parseInt(state.count) || 0;
    const clamped = Math.max(0, Math.min(120, count));
    const percent = clamped / 120;
    const offset = RING_CIRCUMFERENCE * (1 - percent);

    document.getElementById('progressFill').style.strokeDashoffset = offset;
    document.getElementById('progressNum').textContent = clamped;
    document.getElementById('countInput').value = clamped;
    document.getElementById('factCount').textContent = `${clamped} of 120`;

    const remaining = 120 - clamped;
    document.getElementById('remaining').textContent = remaining;

    const yearsLeft = (remaining / 12).toFixed(1);
    document.getElementById('timeLeft').textContent = `${yearsLeft} yrs`;
    document.getElementById('paymentsLeft').textContent = `${remaining} more payments`;

    // Estimated forgiveness date
    const now = new Date();
    const future = new Date(now.getFullYear(), now.getMonth() + remaining, now.getDate());
    const monthNames = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
    document.getElementById('forgivenessDate').textContent =
      remaining === 0 ? 'NOW!' : `${monthNames[future.getMonth()]} ${future.getFullYear()}`;
  }

  function changeCount(delta) {
    state.count = Math.max(0, Math.min(120, (parseInt(state.count) || 0) + delta));
    updateProgress();
    saveState(state);
  }

  function setCount(val) {
    state.count = Math.max(0, Math.min(120, parseInt(val) || 0));
    updateProgress();
    saveState(state);
  }

  // ====== PHASE TOGGLES ======
  function togglePhase(num) {
    state.phasesComplete[num] = !state.phasesComplete[num];
    applyPhaseStates();
    saveState(state);
  }

  function applyPhaseStates() {
    document.querySelectorAll('.phase').forEach(el => {
      const num = el.dataset.phase;
      const btn = el.querySelector('.phase-toggle');
      if (state.phasesComplete[num]) {
        el.classList.add('complete');
        btn.textContent = '✓ Phase Complete · Tap to Undo';
      } else {
        el.classList.remove('complete');
        btn.textContent = 'Mark Phase Complete';
      }
    });
  }

  // ====== STEP CHECKLIST ======
  function setupStepClicks() {
    document.querySelectorAll('.phase').forEach(phaseEl => {
      const phaseNum = phaseEl.dataset.phase;
      phaseEl.querySelectorAll('.step-list li').forEach((li, idx) => {
        const key = `${phaseNum}-${idx}`;
        if (state.stepsChecked[key]) li.classList.add('checked');
        li.addEventListener('click', (e) => {
          e.stopPropagation();
          li.classList.toggle('checked');
          state.stepsChecked[key] = li.classList.contains('checked');
          saveState(state);
        });
      });
    });
  }

  // ====== TONIGHT CHECKLIST ======
  function setupChecklistClicks() {
    document.querySelectorAll('.check-item').forEach(item => {
      const key = item.dataset.check;
      if (state.checklistItems[key]) item.classList.add('checked');
      item.addEventListener('click', () => {
        item.classList.toggle('checked');
        state.checklistItems[key] = item.classList.contains('checked');
        saveState(state);
      });
    });
  }

  // ====== NOTES ======
  let notesTimer;
  function setupNotes() {
    const textarea = document.getElementById('notesArea');
    const status = document.getElementById('notesStatus');
    textarea.value = state.notes || '';

    textarea.addEventListener('input', () => {
      status.textContent = 'Saving...';
      status.classList.remove('saved');
      clearTimeout(notesTimer);
      notesTimer = setTimeout(() => {
        state.notes = textarea.value;
        saveState(state);
        const now = new Date();
        const time = now.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
        status.textContent = `Saved at ${time}`;
        status.classList.add('saved');
      }, 600);
    });
  }

  // ====== COUNTDOWN TO MAY 8 ======
  function updateCountdown() {
    const deadline = new Date('2026-05-08T23:59:59');
    const now = new Date();
    const diff = deadline - now;
    const card = document.getElementById('deadlineCard');
    const cd = document.getElementById('countdown');

    if (diff < 0) {
      card.classList.add('passed');
      cd.textContent = '⚠ Deadline passed — verify recertification was completed';
      return;
    }

    const days = Math.floor(diff / (1000 * 60 * 60 * 24));
    const hours = Math.floor((diff / (1000 * 60 * 60)) % 24);

    if (days > 0) {
      cd.textContent = `${days} days, ${hours} hours remaining`;
    } else {
      const mins = Math.floor((diff / (1000 * 60)) % 60);
      cd.textContent = `${hours}h ${mins}m remaining`;
    }
  }

  // ====== RESET ======
  function resetAll() {
    if (!confirm('Reset all progress, checkmarks, and notes? This cannot be undone.')) return;
    state = {
      count: 37,
      phasesComplete: {},
      stepsChecked: {},
      checklistItems: {},
      notes: ''
    };
    saveState(state);
    location.reload();
  }

  // ====== INIT ======
  document.addEventListener('DOMContentLoaded', () => {
    updateProgress();
    applyPhaseStates();
    setupStepClicks();
    setupChecklistClicks();
    setupNotes();
    updateCountdown();
    setInterval(updateCountdown, 60000);
  });

  // Run immediately if DOM already parsed
  if (document.readyState !== 'loading') {
    updateProgress();
    applyPhaseStates();
    setupStepClicks();
    setupChecklistClicks();
    setupNotes();
    updateCountdown();
    setInterval(updateCountdown, 60000);
  }
</script>

</body>
</html>